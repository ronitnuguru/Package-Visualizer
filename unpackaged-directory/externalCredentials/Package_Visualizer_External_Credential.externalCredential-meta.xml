<?xml version="1.0" encoding="UTF-8"?>
<ExternalCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <authenticationProtocol>Oauth</authenticationProtocol>
    <externalCredentialParameters>
        <parameterGroup>DefaultGroup</parameterGroup>
        <parameterName>Oauth</parameterName>
        <parameterType>AuthProtocolVariant</parameterType>
        <parameterValue>ClientCredentialsClientSecret</parameterValue>
    </externalCredentialParameters>
    <!-- AuthProviderUrl is the OAuth token endpoint. For the Client Credentials
         flow it MUST be the org's own My Domain — Salesforce rejects
         login/test.salesforce.com, and scopes are NOT sent on the token request
         (they live on the External Client App). This value is PER-ORG: each
         subscriber must set it to their own My Domain. It cannot be set via
         ConnectApi (the API has no AuthProtocolVariant vocabulary) or Tooling
         API PATCH (entity not updatable), so subscribers set it in Setup →
         Named Credentials → this External Credential, or by editing this value
         before deploy. The committed value is the ISV dev DevHub's My Domain. -->
    <externalCredentialParameters>
        <parameterGroup>DefaultGroup</parameterGroup>
        <parameterName>AuthProviderUrl</parameterName>
        <parameterType>AuthProviderUrl</parameterType>
        <parameterValue>https://pkgvisualizerlwc2020.my.salesforce.com/services/oauth2/token</parameterValue>
    </externalCredentialParameters>
    <externalCredentialParameters>
        <parameterGroup>PackageVisualizerPrincipal</parameterGroup>
        <parameterName>PackageVisualizerPrincipal</parameterName>
        <parameterType>NamedPrincipal</parameterType>
        <sequenceNumber>1</sequenceNumber>
    </externalCredentialParameters>
    <label>Package Visualizer External Credential</label>
</ExternalCredential>