<?xml version="1.0" encoding="UTF-8" ?>
<!-- Packaged External Credential for the secure Tooling-API self-callout (OAuth
     Client Credentials + Client Secret). Ships with a PLACEHOLDER AuthProviderUrl
     (the OAuth token endpoint); each subscriber sets it to their own My Domain
     (<MyDomain>/services/oauth2/token) in Setup → Named Credentials. Client id/secret
     are NEVER packaged — the subscriber pastes them onto the PackageVisualizerPrincipal
     post-install (wizard → populateClientCredentials, or Setup). -->
<ExternalCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <authenticationProtocol>Oauth</authenticationProtocol>
    <externalCredentialParameters>
        <parameterGroup>DefaultGroup</parameterGroup>
        <parameterName>Oauth</parameterName>
        <parameterType>AuthProtocolVariant</parameterType>
        <parameterValue>ClientCredentialsClientSecret</parameterValue>
    </externalCredentialParameters>
    <externalCredentialParameters>
        <parameterGroup>DefaultGroup</parameterGroup>
        <parameterName>AuthProviderUrl</parameterName>
        <parameterType>AuthProviderUrl</parameterType>
        <parameterValue
    >https://loopback.placeholder.com/services/oauth2/token</parameterValue>
    </externalCredentialParameters>
    <externalCredentialParameters>
        <parameterGroup>PackageVisualizerPrincipal</parameterGroup>
        <parameterName>PackageVisualizerPrincipal</parameterName>
        <parameterType>NamedPrincipal</parameterType>
        <sequenceNumber>1</sequenceNumber>
    </externalCredentialParameters>
    <label>Package Visualizer External Credential</label>
</ExternalCredential>
